{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "target": "ES2022",
    "lib": ["ES2023", "DOM"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "strict": true,
    "paths": {
      "@/*": ["./ui/*"],
      "@root/*": ["./*"]
    },
    "jsx": "react-jsx",
    "types": ["vite/client"]
  },
  "include": ["vite.config.ts", "pipeline/**/*.ts", "pipeline/**/*.tsx"],
  "exclude": ["ui", "node_modules"]
}
